{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "txt",
  "version": "0.8.2",
  "identifier": "ai.james-is-an.textbridge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run vite:dev",
    "beforeBuildCommand": "bun run vite:build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "txt",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: James Dowzard (G54DLMPV94)",
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "10.15"
    },
    "externalBin": ["binaries/textbridge-backend"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFERjg5NUJEMzBFMzVBODYKUldTR1d1TXd2Wlg0SGZoZStQalNtRHg2VWtjNlh1UFJ4dFJtbWRqSjVTM2pNNVZNdUdQZWpmcEgK",
      "endpoints": [
        "https://github.com/jamesdowzard/txt/releases/latest/download/latest.json"
      ]
    },
    "deep-link": {
      "desktop": {
        "schemes": ["textbridge"]
      }
    }
  }
}
