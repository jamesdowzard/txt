{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Textbridge",
  "version": "0.2.0",
  "identifier": "ai.james-is-an.textbridge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run vite:dev",
    "beforeBuildCommand": "bun run vite:build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Textbridge",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: James Dowzard (G54DLMPV94)",
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "10.15"
    },
    "externalBin": ["binaries/textbridge-backend"]
  }
}
