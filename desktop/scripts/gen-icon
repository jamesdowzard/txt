#!/usr/bin/env -S uv run --no-project --with pillow --quiet python3
"""Regenerate Textbridge app icons (stable + dev variants).

Design: a stylised suspension bridge carrying a speech bubble — the bridge
motif from the name, the bubble + ... cue for messaging. Monochrome on a
dark squircle, no brand colour, system-feel. Dev variant warms the chrome
to amber so it's distinguishable in the Dock.

Run:
    ./desktop/scripts/gen-icon
"""
from __future__ import annotations

from pathlib import Path
from PIL import Image, ImageDraw

SIZE = 1024
RADIUS = 230  # squircle corner

REPO = Path(__file__).resolve().parents[2]
ICONS = REPO / "desktop" / "src-tauri" / "icons"


def squircle_base(top: tuple[int, int, int], bottom: tuple[int, int, int]) -> Image.Image:
    """Dark squircle base with a vertical gradient and a faint inner rim."""
    img = Image.new("RGBA", (SIZE, SIZE), (0, 0, 0, 0))
    grad = Image.new("RGB", (1, SIZE), 0)
    gd = ImageDraw.Draw(grad)
    for y in range(SIZE):
        t = y / (SIZE - 1)
        r = int(top[0] * (1 - t) + bottom[0] * t)
        g = int(top[1] * (1 - t) + bottom[1] * t)
        b = int(top[2] * (1 - t) + bottom[2] * t)
        gd.point((0, y), fill=(r, g, b))
    grad = grad.resize((SIZE, SIZE))
    mask = Image.new("L", (SIZE, SIZE), 0)
    ImageDraw.Draw(mask).rounded_rectangle((0, 0, SIZE, SIZE), radius=RADIUS, fill=255)
    img.paste(grad, (0, 0), mask)
    rim = Image.new("RGBA", (SIZE, SIZE), (0, 0, 0, 0))
    ImageDraw.Draw(rim).rounded_rectangle(
        (4, 4, SIZE - 4, SIZE - 4), radius=RADIUS - 4, outline=(255, 255, 255, 28), width=2
    )
    return Image.alpha_composite(img, rim)


def render(
    base_top: tuple[int, int, int],
    base_bottom: tuple[int, int, int],
    chrome: tuple[int, int, int, int],
    chrome_faint: tuple[int, int, int, int],
    bubble: tuple[int, int, int, int],
    dot: tuple[int, int, int, int],
) -> Image.Image:
    img = squircle_base(base_top, base_bottom)
    d = ImageDraw.Draw(img)

    # Bridge deck (horizontal bar)
    deck_y = 760
    d.rectangle((140, deck_y, SIZE - 140, deck_y + 16), fill=chrome)

    # Pylons + cap nodes
    for x in (260, SIZE - 260):
        d.rectangle((x - 10, 280, x + 10, deck_y), fill=chrome)
        d.ellipse((x - 22, 268, x + 22, 312), fill=chrome)

    # Suspension cables (parabolic between pylons)
    pts: list[tuple[float, float]] = []
    for i in range(0, 101, 2):
        t = i / 100
        x = 260 + (SIZE - 520) * t
        y = 290 + 380 * (4 * t * (1 - t))
        pts.append((x, y))
    for i in range(len(pts) - 1):
        d.line([pts[i], pts[i + 1]], fill=chrome_faint, width=4)

    # Vertical hangers
    for i in range(10, 91, 10):
        t = i / 100
        x = 260 + (SIZE - 520) * t
        y = 290 + 380 * (4 * t * (1 - t))
        d.line([(x, y), (x, deck_y)], fill=chrome_faint, width=3)

    # Speech bubble centred above the deck
    d.rounded_rectangle((360, 380, 760, 620), radius=90, fill=bubble)
    d.polygon([(440, 610), (510, 610), (430, 690)], fill=bubble)

    # Three dots — message activity
    cy = 500
    for cx in (470, 560, 650):
        d.ellipse((cx - 18, cy - 18, cx + 18, cy + 18), fill=dot)

    return img


def main() -> None:
    ICONS.mkdir(parents=True, exist_ok=True)

    stable = render(
        base_top=(28, 30, 36),
        base_bottom=(18, 20, 24),
        chrome=(180, 188, 200, 255),
        chrome_faint=(140, 148, 160, 255),
        bubble=(240, 244, 248, 255),
        dot=(28, 30, 36, 255),
    )
    stable_path = ICONS / "icon-1024.png"
    stable.save(stable_path)
    print(f"wrote {stable_path}")

    # Dev variant: same composition, amber-tinted chrome, warmer base
    dev = render(
        base_top=(38, 30, 24),
        base_bottom=(22, 18, 14),
        chrome=(232, 168, 96, 255),
        chrome_faint=(176, 124, 64, 255),
        bubble=(252, 230, 198, 255),
        dot=(40, 28, 16, 255),
    )
    dev_path = ICONS / "icon-dev-1024.png"
    dev.save(dev_path)
    print(f"wrote {dev_path}")


if __name__ == "__main__":
    main()
