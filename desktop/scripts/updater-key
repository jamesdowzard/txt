#!/bin/bash
# Manage the Tauri updater signing key in the macOS keychain.
#
# Sub-commands:
#   check     Exit 0 if the private key + pubkey + password are stored.
#             Exit 1 with setup instructions otherwise.
#   export    Print the private key contents to stdout. Used by the release
#             script via:
#               export TAURI_SIGNING_PRIVATE_KEY="$(./scripts/updater-key export)"
#   pubkey    Print the base64-encoded public key (for tauri.conf.json).
#   password  Print the private-key password to stdout. Used by the release
#             script via:
#               export TAURI_SIGNING_PRIVATE_KEY_PASSWORD="$(./scripts/updater-key password)"
#
# One-time setup (the user runs this once, never the agent):
#   # 1. Pick a strong password and stash it:
#   PW="$(openssl rand -base64 24)"
#   mkdir -p ~/.tauri
#   cargo tauri signer generate --ci -p "$PW" -w ~/.tauri/textbridge-updater.key
#   security add-generic-password -a textbridge-updater -s textbridge-updater \
#     -w "$(cat ~/.tauri/textbridge-updater.key)"
#   security add-generic-password -a textbridge-updater-pub -s textbridge-updater-pub \
#     -w "$(cat ~/.tauri/textbridge-updater.key.pub)"
#   security add-generic-password -a textbridge-updater-password -s textbridge-updater-password \
#     -w "$PW"
#   # Paste the pubkey contents into desktop/src-tauri/tauri.conf.json under
#   # plugins.updater.pubkey, replacing the placeholder.
#
# After setup, ~/.tauri/textbridge-updater.key{,.pub} + the password value
# should be moved to Vaultwarden (or ~/.credentials/) — keychain is the
# source of truth at build time.
set -e

ACCOUNT_PRIV="textbridge-updater"
ACCOUNT_PUB="textbridge-updater-pub"
ACCOUNT_PW="textbridge-updater-password"

usage() {
    cat <<EOF
Usage: $0 <check|export|pubkey|password>

  check     Verify the updater keys + password are present in the keychain.
  export    Print the private key contents to stdout.
  pubkey    Print the base64-encoded public key.
  password  Print the private-key password.
EOF
    exit 1
}

setup_help() {
    cat >&2 <<EOF

Updater key not fully configured in keychain.

One-time setup (run as your user):

  PW="\$(openssl rand -base64 24)"
  mkdir -p ~/.tauri
  cargo tauri signer generate --ci -p "\$PW" -w ~/.tauri/textbridge-updater.key

  security add-generic-password \\
    -a $ACCOUNT_PRIV -s $ACCOUNT_PRIV \\
    -w "\$(cat ~/.tauri/textbridge-updater.key)"
  security add-generic-password \\
    -a $ACCOUNT_PUB -s $ACCOUNT_PUB \\
    -w "\$(cat ~/.tauri/textbridge-updater.key.pub)"
  security add-generic-password \\
    -a $ACCOUNT_PW -s $ACCOUNT_PW \\
    -w "\$PW"

  # Paste the pubkey contents into desktop/src-tauri/tauri.conf.json
  # under plugins.updater.pubkey:
  ./scripts/updater-key pubkey

  # Then move ~/.tauri/textbridge-updater.key{,.pub} and \$PW to Vaultwarden
  # or ~/.credentials/, delete from ~/.tauri/.

EOF
    exit 1
}

cmd_check() {
    if ! security find-generic-password -a "$ACCOUNT_PRIV" -s "$ACCOUNT_PRIV" -w >/dev/null 2>&1; then
        setup_help
    fi
    if ! security find-generic-password -a "$ACCOUNT_PUB" -s "$ACCOUNT_PUB" -w >/dev/null 2>&1; then
        echo "Updater pubkey missing from keychain (account=$ACCOUNT_PUB)." >&2
        setup_help
    fi
    if ! security find-generic-password -a "$ACCOUNT_PW" -s "$ACCOUNT_PW" -w >/dev/null 2>&1; then
        echo "Updater password missing from keychain (account=$ACCOUNT_PW)." >&2
        setup_help
    fi
    echo "Updater keys present in keychain (accounts: $ACCOUNT_PRIV, $ACCOUNT_PUB, $ACCOUNT_PW)."
}

cmd_export() {
    if ! security find-generic-password -a "$ACCOUNT_PRIV" -s "$ACCOUNT_PRIV" -w 2>/dev/null; then
        setup_help
    fi
}

cmd_pubkey() {
    if ! security find-generic-password -a "$ACCOUNT_PUB" -s "$ACCOUNT_PUB" -w 2>/dev/null; then
        setup_help
    fi
}

cmd_password() {
    if ! security find-generic-password -a "$ACCOUNT_PW" -s "$ACCOUNT_PW" -w 2>/dev/null; then
        setup_help
    fi
}

case "${1:-}" in
    check)    cmd_check ;;
    export)   cmd_export ;;
    pubkey)   cmd_pubkey ;;
    password) cmd_password ;;
    *)        usage ;;
esac
