#!/bin/bash
# Build the Go backend as Tauri sidecar binaries.
#
# Default: build both Apple Silicon and Intel slices and lipo them into
# `textbridge-backend-universal-apple-darwin`, which is what Tauri 2's
# `externalBin` picks up when `cargo tauri build --target universal-apple-darwin`
# runs. The per-arch files are also left in place for standalone debugging.
#
# Set BUILD_SIDECAR_HOST_ONLY=1 to build only the host architecture (faster
# dev-loop). That skips the universal lipo step, so the resulting bundle will
# only run on the host arch.
#
# Must run before `cargo tauri build` / `./scripts/dev` / `./scripts/release`.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DESKTOP_DIR="$(dirname "$SCRIPT_DIR")"
REPO_DIR="$(dirname "$DESKTOP_DIR")"
BIN_DIR="$DESKTOP_DIR/src-tauri/binaries"

mkdir -p "$BIN_DIR"
cd "$REPO_DIR"

# Build the web UI first — Go embeds internal/web/static/dist/ which comes from
# `bun run build` under web/. Skip with SKIP_WEB_BUILD=1 if you've already built.
if [[ "${SKIP_WEB_BUILD:-0}" != "1" ]]; then
    echo "==> Building web UI (Vite)"
    (cd "$REPO_DIR/web" && bun install --frozen-lockfile && bun run build)
fi

build_one() {
    local triple="$1" goarch="$2"
    local out="$BIN_DIR/textbridge-backend-$triple"
    echo "==> Building Go backend for $triple"
    CGO_ENABLED=0 GOOS=darwin GOARCH="$goarch" go build -ldflags="-s -w" -o "$out" .
    chmod +x "$out"
    echo "    wrote $out ($(du -h "$out" | cut -f1))"
}

HOST_TRIPLE=$(rustc -vV | awk '/host:/ { print $2 }')

if [[ "${BUILD_SIDECAR_HOST_ONLY:-0}" == "1" ]]; then
    case "$HOST_TRIPLE" in
        aarch64-apple-darwin) build_one aarch64-apple-darwin arm64 ;;
        x86_64-apple-darwin)  build_one x86_64-apple-darwin  amd64 ;;
        *) echo "Unsupported host: $HOST_TRIPLE" >&2; exit 1 ;;
    esac
else
    build_one aarch64-apple-darwin arm64
    build_one x86_64-apple-darwin  amd64
    UNIVERSAL="$BIN_DIR/textbridge-backend-universal-apple-darwin"
    echo "==> Lipo'ing universal binary"
    lipo -create \
        "$BIN_DIR/textbridge-backend-aarch64-apple-darwin" \
        "$BIN_DIR/textbridge-backend-x86_64-apple-darwin" \
        -output "$UNIVERSAL"
    chmod +x "$UNIVERSAL"
    echo "    wrote $UNIVERSAL ($(du -h "$UNIVERSAL" | cut -f1))"
fi
